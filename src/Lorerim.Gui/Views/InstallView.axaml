<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lorerim.Gui.ViewModels"
             xmlns:eng="using:Lorerim.Gui.Services.Engine"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Lorerim.Gui.Views.InstallView"
             x:DataType="vm:InstallViewModel">

    <UserControl.Styles>
        <!-- Status glyph tones for the preflight list -->
        <Style Selector="TextBlock.glyph">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.glyph.ok">
            <Setter Property="Foreground" Value="{StaticResource RuneOk}"/>
        </Style>
        <Style Selector="TextBlock.glyph.warn">
            <Setter Property="Foreground" Value="{StaticResource RuneWarn}"/>
        </Style>
        <Style Selector="TextBlock.glyph.fail">
            <Setter Property="Foreground" Value="{StaticResource RuneFail}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Left">

            <StackPanel Spacing="3">
                <TextBlock Classes="eyebrow" Text="ONE-CLICK DEPLOYMENT"/>
                <TextBlock Classes="h1" Text="Install LoreRim"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="Skyrim Anniversary Edition · ~250 GB downloaded · ~330 GB installed · hours unattended"/>
            </StackPanel>

            <!-- Hero: paths, auth, the one button -->
            <Border Classes="card-hero">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="110,*,Auto" RowDefinitions="Auto,10,Auto,10,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Install to" Classes="muted"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InstallDir}"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Margin="8,0,0,0"
                                Command="{Binding BrowseInstallDirCommand}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Downloads" Classes="muted"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DownloadDir}"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="Browse…" Margin="8,0,0,0"
                                Command="{Binding BrowseDownloadDirCommand}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Resolution" Classes="muted"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Resolutions}"
                                  SelectedItem="{Binding SelectedResolution}"/>
                    </Grid>

                    <!-- Nexus status reads as one unit: dot, text, and the action beside it -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="●" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource RuneOk}"
                                   IsVisible="{Binding IsSignedIn}"/>
                        <TextBlock Text="○" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource RuneMuted}"
                                   IsVisible="{Binding !IsSignedIn}"/>
                        <TextBlock Text="{Binding AuthStatus}" VerticalAlignment="Center"/>
                        <Button Content="Sign in to Nexus" Command="{Binding SignInCommand}"
                                IsVisible="{Binding !IsSignedIn}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource RuneHairline}"/>

                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Button Classes="accent" MinWidth="240" MinHeight="48"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                IsEnabled="{Binding CanInstall}"
                                Command="{Binding InstallCommand}">
                            <TextBlock Text="INSTALL LORERIM" FontSize="14" FontWeight="SemiBold"
                                       LetterSpacing="2"/>
                        </Button>
                        <Button MinHeight="48" Padding="18,10" Content="Cancel"
                                VerticalContentAlignment="Center"
                                IsVisible="{Binding IsBusy}"
                                Command="{Binding CancelCommand}"/>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding CheckResultText}" TextWrapping="Wrap"/>
                            <TextBlock Classes="muted" FontSize="12" TextWrapping="Wrap"
                                       Text="Already installed? This same button updates or repairs it in place."/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Preflight checklist: filled automatically when the page opens -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Re-check" Padding="12,4"
                                Command="{Binding RunPreflightCommand}"/>
                        <TextBlock Classes="eyebrow" Text="SYSTEM CHECKS" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Checks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CheckRow">
                                <Grid ColumnDefinitions="26,190,*" Margin="0,3">
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}" Classes="glyph"
                                               Classes.ok="{Binding IsOk}"
                                               Classes.warn="{Binding IsWarn}"
                                               Classes.fail="{Binding IsFail}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Classes="muted"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Install phases -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding OverallCounter}"
                                   Classes="mono muted"/>
                        <TextBlock Classes="eyebrow" Text="INSTALL STEPS"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Phases}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PhaseRow">
                                <Grid ColumnDefinitions="26,280,*" Margin="0,3"
                                      Opacity="{Binding Emphasis}">
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}"
                                               Width="20" TextAlignment="Center"
                                               Foreground="{StaticResource RuneBrass}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Classes="muted"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Manual downloads (rare with Premium) -->
            <Border Classes="card" IsVisible="{Binding ShowManualDownloads}"
                    BorderBrush="{StaticResource RuneBrass}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow" Text="MANUAL DOWNLOADS NEEDED"/>
                    <TextBlock Classes="muted" TextWrapping="Wrap"
                               Text="These files can't be fetched automatically. Download each one into your downloads folder, then continue."/>
                    <ItemsControl ItemsSource="{Binding ManualDownloads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="eng:ManualDownload">
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,3">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               FontWeight="SemiBold" Margin="0,0,10,0"
                                               VerticalAlignment="Center"/>
                                    <SelectableTextBlock Grid.Column="1" Text="{Binding Url}"
                                                         Classes="muted" VerticalAlignment="Center"
                                                         TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="Open" Padding="10,3"
                                            Margin="8,0,0,0"
                                            IsVisible="{Binding Url, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Command="{Binding $parent[ItemsControl].((vm:InstallViewModel)DataContext).OpenUrlCommand}"
                                            CommandParameter="{Binding Url}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Classes="accent" Content="I've downloaded them — continue"
                            Command="{Binding ContinueManualDownloadsCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Per-file progress grid -->
            <Border Classes="card" IsVisible="{Binding !!FileRows.Count}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow" Text="FILES"/>
                    <DataGrid ItemsSource="{Binding FileRows}" Height="260"
                              IsReadOnly="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phase" Binding="{Binding Phase}" Width="130"/>
                            <DataGridTemplateColumn Header="Progress" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:FileProgressRow">
                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}"
                                                     Height="8" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- First-launch guidance -->
            <Border Classes="card" IsVisible="{Binding ShowFirstLaunchGuide}"
                    BorderBrush="{StaticResource RuneBrass}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow" Text="BEFORE YOUR FIRST LAUNCH"/>
                    <TextBlock TextWrapping="Wrap" Text="LoreRim is installed and 'LoreRim' is in your Steam library. A few things to know:"/>
                    <TextBlock TextWrapping="Wrap" Classes="muted" Text="• Launch it from Steam — Mod Organizer 2 opens. Pick your profile on the left (Default or Ultra) and press Run."/>
                    <TextBlock TextWrapping="Wrap" Classes="muted" Text="• The first launch takes several minutes (Proton setup + shader compilation). A black screen or slow menus at first are normal."/>
                    <TextBlock TextWrapping="Wrap" Classes="muted" Text="• Do not click the 'Unlock' button in Mod Organizer while the game is starting."/>
                    <TextBlock TextWrapping="Wrap" Classes="muted" Text="• Don't let Steam update Skyrim afterwards — LoreRim manages its own game files."/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
